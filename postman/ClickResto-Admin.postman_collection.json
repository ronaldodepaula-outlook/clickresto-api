        {
          "name": "Cadastro trial",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{base_url}}/public/cadastro-trial",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"empresa\": {\n    \"nome\": \"Restaurante Exemplo\",\n    \"nome_fantasia\": \"Resto Ex\",\n    \"cnpj\": \"00.000.000/0001-00\",\n    \"telefone\": \"11999999999\",\n    \"email\": \"contato@resto.com\",\n    \"endereco\": \"Rua X, 123\",\n    \"cidade\": \"Sao Paulo\",\n    \"estado\": \"SP\"\n  },\n  \"usuario\": {\n    \"nome\": \"Admin\",\n    \"email\": \"admin@resto.com\",\n    \"senha\": \"123456\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.json().confirmacao_url) { pm.environment.set('confirmacao_token', pm.response.json().confirmacao_url.split('token=')[1] || ''); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Confirmar email",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/public/confirmar-email?token={{confirmacao_token}}",
            "body": null
          },
          "event": []
        }
      ]

{
  "info": {
    "name": "ClickResto - Gestao de Usuarios (Empresa)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost/clickresto-api/public/api/v1"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "empresa_id",
      "value": "1"
    },
    {
      "key": "usuario_id",
      "value": "1"
    },
    {
      "key": "perfil_id",
      "value": "2"
    },
    {
      "key": "permissao_id",
      "value": "1"
    },
    {
      "key": "usuario_perfil_id",
      "value": "1"
    },
    {
      "key": "perfil_permissao_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@empresa.com\",\n  \"senha\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Usuarios (Empresa)",
      "item": [
        {
          "name": "List Usuarios",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Empresa-Id", "value": "{{empresa_id}}" }
            ],
            "url": {
              "raw": "{{base_url}}/usuarios?per_page=15",
              "host": ["{{base_url}}"],
              "path": ["usuarios"],
              "query": [
                { "key": "per_page", "value": "15" }
              ]
            }
          },
          "description": "Empresa-specific. Envia X-Empresa-Id quando o usuario autenticado nao possui empresa_id."
        },
        {
          "name": "Create Usuario",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Empresa-Id", "value": "{{empresa_id}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Novo Usuario\",\n  \"email\": \"novo@empresa.com\",\n  \"senha\": \"123456\",\n  \"ativo\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/usuarios",
              "host": ["{{base_url}}"],
              "path": ["usuarios"]
            }
          }
        },
        {
          "name": "Get Usuario",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Empresa-Id", "value": "{{empresa_id}}" }
            ],
            "url": {
              "raw": "{{base_url}}/usuarios/{{usuario_id}}",
              "host": ["{{base_url}}"],
              "path": ["usuarios", "{{usuario_id}}"]
            }
          }
        },
        {
          "name": "Update Usuario",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Empresa-Id", "value": "{{empresa_id}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Usuario Atualizado\",\n  \"email\": \"usuario@empresa.com\",\n  \"senha\": \"123456\",\n  \"ativo\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/usuarios/{{usuario_id}}",
              "host": ["{{base_url}}"],
              "path": ["usuarios", "{{usuario_id}}"]
            }
          }
        },
        {
          "name": "Delete Usuario",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-Empresa-Id", "value": "{{empresa_id}}" }
            ],
            "url": {
              "raw": "{{base_url}}/usuarios/{{usuario_id}}",
              "host": ["{{base_url}}"],
              "path": ["usuarios", "{{usuario_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Usuario-Perfis (Vinculo)",
      "item": [
        {
          "name": "List Usuario-Perfis",
          "request": {
            "method": "GET",

          }
        },
        {
          "name": "Update Usuario-Perfil",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuario_id\": {{usuario_id}},\n  \"perfil_id\": {{perfil_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/usuario-perfis/{{usuario_perfil_id}}",
              "host": ["{{base_url}}"],
              "path": ["usuario-perfis", "{{usuario_perfil_id}}"]
            }
          }
        },
        {
          "name": "Delete Usuario-Perfil",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/usuario-perfis/{{usuario_perfil_id}}",
              "host": ["{{base_url}}"],
              "path": ["usuario-perfis", "{{usuario_perfil_id}}"]
            }
          }
        }
      ]
    },
